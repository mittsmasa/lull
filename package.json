{
  "name": "lull",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "next dev",
    "dev:preview": "NEXT_PUBLIC_VERCEL_ENV=preview next dev",
    "build": "next build && serwist build",
    "start": "next start",
    "lint": "biome check .",
    "lint:fix": "biome check --fix .",
    "format": "biome format --write .",
    "prepare": "test -n \"$CI\" || next typegen",
    "type-check": "next typegen && tsc --noEmit",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build",
    "test": "vitest",
    "test:unit": "vitest run --project unit",
    "test:db": "vitest run --project db",
    "test:vrt": "VRT=1 vitest run --project storybook",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:push": "drizzle-kit push",
    "db:studio": "drizzle-kit studio"
  },
  "packageManager": "pnpm@11.9.0",
  "engines": {
    "node": "24.18.0"
  },
  "dependencies": {
    "@emulators/adapter-next": "0.8.0",
    "@emulators/google": "0.8.0",
    "@hono/zod-validator": "0.8.0",
    "@libsql/client": "0.17.4",
    "@phosphor-icons/react": "2.1.10",
    "@serwist/next": "9.5.7",
    "@tailwindcss/postcss": "4.3.3",
    "better-auth": "1.6.23",
    "class-variance-authority": "0.7.1",
    "clsx": "2.1.1",
    "drizzle-orm": "0.45.2",
    "hono": "4.12.30",
    "html5-qrcode": "2.3.8",
    "motion": "12.41.0",
    "next": "16.2.10",
    "next-themes": "0.4.6",
    "postcss": "8.5.19",
    "qrcode": "1.5.4",
    "radix-ui": "1.6.2",
    "react": "19.2.7",
    "react-dom": "19.2.7",
    "resend": "6.14.0",
    "server-only": "0.0.1",
    "serwist": "9.5.7",
    "sonner": "2.0.7",
    "stripe": "22.3.2",
    "tailwind-merge": "3.6.0",
    "tailwindcss": "4.3.3",
    "tw-animate-css": "1.4.0",
    "zod": "4.4.3"
  },
  "devDependencies": {
    "@biomejs/biome": "2.5.4",
    "@serwist/build": "9.5.7",
    "@serwist/cli": "9.5.7",
    "@storybook/addon-a11y": "10.4.6",
    "@storybook/addon-docs": "10.4.6",
    "@storybook/addon-vitest": "10.4.6",
    "@storybook/nextjs-vite": "10.4.6",
    "@types/node": "25.9.5",
    "@types/qrcode": "1.5.6",
    "@types/react": "19.2.17",
    "@types/react-dom": "19.2.3",
    "@vitest/browser-playwright": "4.1.10",
    "@vitest/coverage-v8": "4.1.10",
    "drizzle-kit": "0.31.10",
    "lefthook": "2.1.10",
    "playwright": "1.61.1",
    "storybook": "10.4.6",
    "storybook-addon-vrt": "0.1.0",
    "typescript": "6.0.3",
    "vite": "8.1.5",
    "vitest": "4.1.10"
  }
}
